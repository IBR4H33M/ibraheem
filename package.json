{
  "name": "ibraheem-portfolio",
  "version": "1.0.0",
  "description": "Personal portfolio website for ibraheemibnanwar.me",
  "main": "server/index.js",
  "scripts": {
    "start": "NODE_ENV=production node server/index.js",
    "build": "cd client && npm install && npm run build",
    "server": "nodemon server/index.js",
    "client": "npm start --prefix client",
    "flask": "cd ml-service-GradePredict && python app.py",
    "flask-product-review": "cd ml-service-ProductReview && python app.py",
    "dev": "concurrently \"npm run server\" \"npm run client\" \"npm run flask\" \"npm run flask-product-review\"",
    "install-all": "npm install && cd client && npm install"
  },
  "keywords": [
    "portfolio",
    "mern",
    "personal-website"
  ],
  "author": "Ibraheem Ibn Anwar",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^1.41.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.0.3",
    "multer": "^2.1.1",
    "multer-storage-cloudinary": "^4.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  }
}
